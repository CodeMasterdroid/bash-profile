alias git-echo-development="echo development | copy_to_clipboard"
alias git-branch-development="git checkout -b development"
alias git-checkout-development="git checkout development"
alias git-feature-checkout-development="git checkout feature/git-init"
alias git-feature-pull-development="git checkout feature/git-init && git pull origin feature/git-init"
alias git-commit-development='git commit -m "Development"'
alias git-force-push-development="git push origin development --force"
alias git-push-development="git push origin development"
alias git-merge-development="echo 'Step 1: checkout feature/git-init' && git checkout feature/git-init && echo 'Step 2: pull latest from origin/feature/git-init' && git pull origin feature/git-init && echo 'Step 3: checkout development' && git checkout development && echo 'Step 4: merge feature/git-init into development' && git merge feature/git-init"
alias git-delete-force-development="git checkout feature/git-init && git branch -D development"
alias git-pull-development="git checkout development && git pull origin development"
alias git-pull-development-api="cd-api && git checkout development && git pull origin development"
alias git-pull-development-fmc="cd-fmc && git checkout development && git pull origin development"
alias git-pull-development-web="cd-web && git checkout development && git pull origin development"
alias git-title-development-web="echo ': Development' | copy_to_clipboard"

